float applyCARules(float state, float total, float average, float previous) {
    if (average >= 254.0) {
        return 0.0;
    } else if (average <= 1.0) {
        return 255.0;
    } else {
        float nextState = state + average;
        if (previous > 0.0) nextState -= previous;
        return clamp(nextState, 0.0, 255.0);
    }
}
